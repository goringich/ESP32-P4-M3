	@echo "... lp_i2s_pdm.s"
	@echo "... lp_i2s_std.obj"
	@echo "... lp_i2s_std.i"
	@echo "... lp_i2s_std.s"
	@echo "... lp_i2s_vad.obj"
	@echo "... lp_i2s_vad.i"
	@echo "... lp_i2s_vad.s"
.PHONY : help



#=============================================================================
# Special targets to cleanup operation of make.

# Special rule to run CMake to check the build system integrity.
# No rule that depends on this can have commands that come from listfiles
# because they might be regenerated.
cmake_check_build_system:
	cd /home/goringich/hello_p4/build && $(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles/Makefile.cmake 0
.PHONY : cmake_check_build_system

